# ─────────────────────────────────────────────────────────────
# Server-only (no VITE_ prefix — read only inside /api/lead.ts)
# ─────────────────────────────────────────────────────────────

# Make.com incoming webhook URL. The submit endpoint forwards validated
# lead payloads here; the Make scenario is responsible for storing the
# lead and sending the team WhatsApp notification. No Pulppo integration
# in V1.
MAKE_WEBHOOK_URL=

# Optional shared secret sent as the X-Webhook-Secret header, so the Make
# scenario can verify requests actually came from this endpoint.
MAKE_WEBHOOK_SECRET=

# Optional: Upstash Redis REST credentials for durable, cross-instance IP
# rate limiting. Without these, rate limiting falls back to an in-memory
# counter that only holds within a single warm serverless instance
# (best-effort, not durable across cold starts / multiple instances).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────────
# Public vars (VITE_ prefix — inlined into the client bundle on purpose)
# ─────────────────────────────────────────────────────────────

# Google Maps JS API key, same key/pattern as the authenticated ACM tool.
# Restrict it to this domain in Google Cloud Console -> Credentials.
# Without it, the location step's map falls back to a static illustrative
# graphic instead of failing.
VITE_GOOGLE_MAPS_API_KEY=
